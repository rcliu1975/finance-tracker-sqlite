{
  "name": "finance-tracker-sqlite",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "config:generate": "node scripts/generate-firebase-config.js",
    "import:records": "node scripts/import-records-cli.js",
    "sqlite:import": "python3 scripts/import-to-sqlite.py",
    "sqlite:import-firestore": "python3 scripts/import-to-sqlite.py firestore",
    "sqlite:import-csv": "python3 scripts/import-to-sqlite.py csv",
    "sqlite:import-items": "python3 scripts/import-to-sqlite.py items",
    "sqlite:bridge": "python3 scripts/sqlite-http-bridge.py",
    "sqlite:export-json": "python3 scripts/export-sqlite-to-json.py",
    "sqlite:export-items": "python3 scripts/export-items-from-sqlite.py",
    "sqlite:export-records": "python3 scripts/export-records-from-sqlite.py",
    "sqlite:rebuild-snapshots": "python3 scripts/rebuild-sqlite-snapshots.py",
    "sqlite:verify-db": "python3 scripts/verify-sqlite-db.py",
    "rebuild:monthly-snapshots": "node scripts/rebuild-monthly-snapshots.js",
    "serve": "npm run config:generate && python3 -m http.server 5173 --bind 0.0.0.0",
    "cleanup:orphan-users": "node scripts/cleanup-orphan-users.js",
    "cleanup:orphan-users:apply": "node scripts/cleanup-orphan-users.js --apply",
    "firebase:login": "npx --yes firebase-tools login",
    "firebase:emulators": "npm run config:generate && mkdir -p .firebase/emulator-data && npx --yes firebase-tools emulators:start --only auth,firestore --import=.firebase/emulator-data --export-on-exit=.firebase/emulator-data",
    "firebase:deploy": "npm run config:generate && npx --yes firebase-tools deploy --only hosting",
    "firebase:deploy:rules": "npx --yes firebase-tools deploy --only firestore:rules"
  }
}
