{
  "firestore": {
    "rules": "firestore.rules"
  },
  "emulators": {
    "auth": {
      "host": "127.0.0.1",
      "port": 9099
    },
    "firestore": {
      "host": "127.0.0.1",
      "port": 8080
    },
    "ui": {
      "enabled": true,
      "host": "127.0.0.1",
      "port": 4000
    }
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebaserc.example",
      ".gitignore",
      ".git/**",
      "README.md",
      "**/*.md",
      "firestore.rules",
      "scripts/**",
      "sqlite/**",
      ".tmp/**",
      "test.html",
      "package.json",
      "package-lock.json",
      "*.csv",
      "*.db",
      "*.sqlite",
      "*.sqlite3",
      "chrome-dom.txt",
      "edge-dom.txt",
      "app-config.example.js",
      "firebase-config.example.js",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=300"
          }
        ]
      }
    ]
  }
}
