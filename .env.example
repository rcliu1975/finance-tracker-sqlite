# `firebase` 會連 Firebase / Firestore；`sqlite` 可配合 APP_SQLITE_API_BASE_URL 連本機 SQLite bridge。
APP_STORAGE_BACKEND=firebase
APP_LOCAL_USER_ID=local-user
APP_SQLITE_SEED_PATH=
APP_SQLITE_API_BASE_URL=

# Firebase Web App 設定
FIREBASE_API_KEY=YOUR_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
FIREBASE_APP_ID=YOUR_APP_ID

# 本機開發切換
FIREBASE_USE_EMULATORS=true

# 若要讓其他裝置透過 Tailscale 連入，這裡請填主機的 Tailscale IP 或可解析主機名。
# 若留空，前端會退回使用目前頁面的 hostname。
FIREBASE_EMULATOR_HOST=
FIREBASE_AUTH_EMULATOR_PORT=9099
FIREBASE_FIRESTORE_EMULATOR_PORT=8080
FIREBASE_EMULATOR_UI_PORT=4000
